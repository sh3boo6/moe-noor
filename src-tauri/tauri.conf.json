{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Moe Noor Data",
  "version": "1.0.3",
  "identifier": "com.moenoordata.desktop",
  "mainBinaryName": "moe-noor-data",
  "build": {
    "frontendDist": "../.output/public",
    "devUrl": "http://localhost:3001",
    "beforeDevCommand": "pnpm dev --port 3001",
    "beforeBuildCommand": "cross-env TAURI_APP=true pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Moe Noor Data",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
